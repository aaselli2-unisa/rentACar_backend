# Copy this file to .env.
# Keep only non-sensitive values here.
# Put credentials in files under ./secrets (see secrets/README.md).

# App
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080/
JWT_EXPIRATION_MS=86400000

# Database (non-sensitive)
DB_URL=jdbc:postgresql://postgres:5432/rentacar
DB_USERNAME=postgres

# Mail host config (credentials are in Docker secrets)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Secret files required in ./secrets:
# DB_PASSWORD
# JWT_SECRET
# CLOUDINARY_CLOUD_NAME
# CLOUDINARY_API_KEY
# CLOUDINARY_API_SECRET
# MAIL_USERNAME
# MAIL_PASSWORD



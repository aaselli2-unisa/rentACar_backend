<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        Questo file sopprime falsi positivi per l'OWASP Dependency Check.
    -->

    <!--
        La vulnerabilità è sfruttabile SOLO se il percorso /swagger-ui/** è
        accessibile senza autenticazione. Siccome noi abbiamo già risolto questa vulernabilità
        rendendo autenticato l'ednpoint la possiamo sopprimere
    -->
    <suppress>
        <notes>
               Falso positivo: Swagger protetto da autenticazione JWT (SecurityConfig patch V13).
               Revisione: 2026-04-16</notes>
        <packageUrl regex="true">^pkg:maven/io\.springfox/.*@3\.0\.0$</packageUrl>
        <cve>CVE-2022-34117</cve>
    </suppress>

    <!--
        La vulnerabilità richiede che un attaccante possa inviare definizioni
        OpenAPI malformate al parser. Le definizione openapi
        sono generate staticamente dal codice sorgente a compile-time
        Inoltre Swagger è protetto da autenticazione ADMIN
    -->
    <suppress>
        <notes>
               Falso positivo: definizioni OpenAPI generate a compile-time e
               Swagger protetto da autenticazione ADMIN.
               Revisione: 2026-04-18</notes>
        <packageUrl regex="true">^pkg:maven/io\.springfox/.*@3\.0\.0$</packageUrl>
        <cve>CVE-2023-38286</cve>
    </suppress>

    <!--
        anche se usa httpclient4.4, usa HttpClient esclusivamente per chiamate outbound
        verso api.cloudinary.com, l'URL non è mai derivato da input utente,
        quindi il vettore di attacco non sussiste
    -->
    <suppress>
        <notes>
               Falso positivo: HttpCLient usato solo per chiamate outbound a
               api.cloudinary.com (URL fisso).
               Revisione: 2026-04-16</notes>
        <packageUrl regex="true">^pkg:maven/com\.cloudinary/cloudinary-http44@.*$</packageUrl>
        <cve>CVE-2020-13956</cve>
    </suppress>

</suppressions>